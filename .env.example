# ═══════════════════════════════════════════════════════════════════
#  SEO Analyzer — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── PostgreSQL connection ───────────────────────────────────────────
# Required for audit persistence. Without this, results are returned
# directly but NOT saved (in-memory mode).
#
# Local Linux server:
#   DATABASE_URL=postgresql://seo_user:password@localhost:5432/seo_analyzer
# Remote server:
#   DATABASE_URL=postgresql://seo_user:password@1.2.3.4:5432/seo_analyzer
# Docker (uses container name):
#   DATABASE_URL=postgresql://seo_user:password@postgres:5432/seo_analyzer
DATABASE_URL=

# ── PostgreSQL credentials (docker-compose only) ───────────────────
# Only needed when running via docker-compose (creates the Postgres container).
POSTGRES_DB=seo_analyzer
POSTGRES_USER=seo_user
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ── Frontend build-time (Vite) ─────────────────────────────────────
# Leave empty for same-origin deployment (Docker / PaaS).
# Set only if API is on a different host than the frontend.
VITE_API_BASE_URL=

# ── Optional: Scrapling sidecar ────────────────────────────────────
# Python JS-rendering sidecar — set automatically by docker-compose.
# When unset, routes fall back to native fetch() automatically.
# SCRAPLING_SIDECAR_URL=http://localhost:5000

# ── Optional: PageSpeed Insights API key ──────────────────────────
# When set, performance checks include real Core Web Vitals from Google.
# PAGESPEED_API_KEY=
